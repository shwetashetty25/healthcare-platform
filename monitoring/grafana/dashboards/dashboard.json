  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "title": "API Request Rate (HTTP Requests Total)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-datasource"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-datasource"
          },
          "editorMode": "code",
          "expr": "sum(rate(http_requests_total[1m])) by (method, route, status_code)",
          "legendFormat": "{{method}} {{route}} ({{status_code}})",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "title": "System Memory Usage (Node RSS)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-datasource"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-datasource"
          },
          "editorMode": "code",
          "expr": "process_resident_memory_bytes / 1024 / 1024",
          "legendFormat": "Memory RSS (MB)",
          "range": true,
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "5s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["healthcare", "devops"],
  "time": {
    "from": "now-15m",
    "to": "now"
